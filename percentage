#include <stdio.h>
int main()
{
   float m1,m2,m3,m4,m5,total,percentage;
   printf("Enter mark of five subject:");
   scanf("%f%f%f%f%f",&m1,&m2,&m3,&m4,&m5);
   total=(m1+m2+m3+m4+m5);
   percentage=total/5;
   printf("total=%.0f\n",total);
   printf("percentage=%.2f%%",percentage);
   return 0;
}
